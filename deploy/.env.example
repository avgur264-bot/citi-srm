# Скопируйте этот файл в .env  (cp .env.example .env)  и при необходимости измените.

# Адрес, по которому открывается система.
#  - Для старта по IP-адресу сервера оставьте :80
#  - Когда привяжете домен, впишите его — Caddy автоматически включит HTTPS.
#    Пример: SITE_ADDRESS=srm.вашакомпания.ru
#    (для домена нужно заранее направить A-запись DNS на IP сервера и открыть порт 443)
SITE_ADDRESS=:80
